# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=oryno_webapp

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS Origins
CORS_ORIGINS=*

# Stripe Configuration (placeholder - can be configured later)
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# MTN MoMo Configuration (placeholder - can be configured later)
MTN_MOMO_PRIMARY_KEY=placeholder
MTN_MOMO_SECONDARY_KEY=placeholder
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_CALLBACK_URL=https://oryno-transfer.preview.emergentagent.com/api/payments/momo/callback

# Use local storage for file uploads
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=/app/backend/uploads

# SMTP Mock Mode (no actual emails sent)
SMTP_MOCK_MODE=true

# Frontend URL
FRONTEND_URL=https://oryno-transfer.preview.emergentagent.com

# Environment
ENVIRONMENT=development
